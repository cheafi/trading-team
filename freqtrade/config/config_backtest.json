{
  "trading_mode": "futures",
  "margin_mode": "isolated",
  "max_open_trades": 4,
  "stake_currency": "USDT",
  "stake_amount": 200,
  "tradable_balance_ratio": 0.80,
  "dry_run": true,
  "dry_run_wallet": 10000,

  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "pair_whitelist": [
      "ETH/USDT:USDT",
      "BTC/USDT:USDT",
      "SOL/USDT:USDT",
      "BNB/USDT:USDT",
      "XRP/USDT:USDT",
      "DOGE/USDT:USDT"
    ],
    "pair_blacklist": []
  },

  "pairlists": [
    { "method": "StaticPairList" }
  ],

  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },

  "order_types": {
    "entry": "limit",
    "exit": "limit",
    "stoploss": "market",
    "stoploss_on_exchange": true
  },

  "api_server": {
    "enabled": false,
    "listen_ip_address": "127.0.0.1",
    "listen_port": 8081,
    "jwt_secret_key": "__overridden_by_env__",
    "username": "__overridden_by_env__",
    "password": "__overridden_by_env__"
  },

  "timeframe": "5m",
  "startup_candle_count": 200
}
