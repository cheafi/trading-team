# ============================================================
# 🏆 Cheafi Trading Team — Environment Variables
# ============================================================
# Copy: cp .env.example .env

# ── LLM API Keys ────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Azure OpenAI (if using Azure)
AZURE_OPENAI_ENABLED=true
AZURE_OPENAI_ENDPOINT=https://cog-sandbox-dev-eastus2-001.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5-chat
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ── Freqtrade ───────────────────────────────────────────────
FREQTRADE_API_PORT=8080
FREQTRADE_USER=freqtrader
FREQTRADE_PASS=SuperSecure123

# ── Exchange API (Binance example) ──────────────────────────
EXCHANGE_KEY=your-exchange-api-key
EXCHANGE_SECRET=your-exchange-api-secret

# ── Dashboard ───────────────────────────────────────────────
DASHBOARD_PORT=3000
REDIS_PORT=6379

# ── General ─────────────────────────────────────────────────
TZ=Asia/Hong_Kong
# ── Discord Bot ─────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_NAME=Trading CCNODE_ENV=production
