FROM node:22-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip curl jq tini \
    ca-certificates gnupg && \
    install -m 0755 -d /etc/apt/keyrings && \
    curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg && \
    chmod a+r /etc/apt/keyrings/docker.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian bookworm stable" > /etc/apt/sources.list.d/docker.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends docker-ce-cli docker-compose-plugin && \
    pip3 install --no-cache-dir --break-system-packages scikit-learn numpy && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy shared libraries
COPY shared/ ./shared/

# Copy agent configs and scripts
COPY agents/ ./agents/

# Install Node dependencies
COPY agents/package.json ./
RUN npm install --production

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -sf http://localhost:3001/health || exit 1

# Run as non-root
RUN groupadd -r trading && useradd -r -g trading -d /app trading && chown -R trading:trading /app
USER trading

EXPOSE 3001

ENTRYPOINT ["tini", "--"]
CMD ["node", "agents/coordinator.mjs"]
