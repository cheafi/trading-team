# ============================================================
# 🏆 CC Trading Team — Environment Variables
# ============================================================
# Copy: cp .env.example .env

# ── LLM API Keys ────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Unified LLM gateway (optional)
# OpenAI-compatible format: replace https://api.openai.com/v1 -> https://reelxai.com/v1
# Gemini format: replace https://generativelanguage.googleapis.com/v1beta -> https://reelxai.com/v1beta
# Claude format: replace https://api.anthropic.com/v1/messages -> https://reelxai.com/v1/messages
LLM_API_BASE_URL=https://reelxai.com/v1
LLM_GEMINI_BASE_URL=https://reelxai.com/v1beta
LLM_CLAUDE_MESSAGES_URL=https://reelxai.com/v1/messages
LLM_BALANCE_URL=https://query.llmxapi.com
LLM_API_KEY=
LLM_MODEL_PRIMARY=gpt-5.4
LLM_MODEL_RESEARCH=gemini-3.1-pro-preview
LLM_MODEL_FAST=gemini-3.1-flash-lite-preview

# Azure OpenAI (if using Azure)
AZURE_OPENAI_ENABLED=true
AZURE_OPENAI_ENDPOINT=https://cog-sandbox-dev-eastus2-001.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5-chat
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ── Freqtrade ───────────────────────────────────────────────
FREQTRADE_API_PORT=8080
FREQTRADE_USER=freqtrader
FREQTRADE_PASS=SuperSecure123

# ── Exchange API (Binance example) ──────────────────────────
EXCHANGE_KEY=your-exchange-api-key
EXCHANGE_SECRET=your-exchange-api-secret

# ── Dashboard ───────────────────────────────────────────────
DASHBOARD_PORT=3000
REDIS_PORT=6379

# ── General ─────────────────────────────────────────────────
TZ=Asia/Hong_Kong
# ── Discord Bot ─────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_NAME=Trading CC
NODE_ENV=production
